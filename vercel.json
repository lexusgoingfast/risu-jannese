{
  "redirects": [
    {
      "source": "/trayma.html",
      "destination": "/trayma",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/closed.html"
    },
    {
      "source": "/trayma",
      "destination": "/closed.html"
    },
    {
      "source": "/trayma/:path*",
      "destination": "/closed.html"
    },
    {
      "source": "/projects",
      "destination": "/closed.html"
    },
    {
      "source": "/projects/:path*",
      "destination": "/closed.html"
    }
  ]
}
